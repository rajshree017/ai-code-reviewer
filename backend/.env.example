ANTHROPIC_API_KEY=your_claude_api_key_here

# Create this OAuth App at: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Must exactly match the "Authorization callback URL" set in your GitHub OAuth App
GITHUB_REDIRECT_URI=http://localhost:8000/auth/callback

# Where your frontend is hosted (used to redirect back after login)
FRONTEND_URL=http://localhost:5173

# --- Optional: automatic webhook-triggered reviews ---
# Only needed if you want the bot to auto-review every new/updated PR (see README "Webhook" section).
# 1. Generate any random string for this, and use the SAME string in your GitHub webhook settings.
GITHUB_WEBHOOK_SECRET=choose_any_random_string

# 2. Generate a GitHub Personal Access Token (classic) with 'repo' scope at:
#    https://github.com/settings/tokens
WEBHOOK_GITHUB_TOKEN=your_github_personal_access_token
